# ENSA environment variables
# Copy this file to .env and fill in the values you need.
# The core dashboard works WITHOUT any of these — they are all optional.

# ── LLM (optional — for AI-enhanced narrative in the dashboard) ────────────
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT-4o-mini
OPENAI_API_KEY=sk-...

# ── Database ────────────────────────────────────────────────────────────────
# Leave blank to use the default SQLite file at the project root.
# DB_PATH=/path/to/custom/ensa.db

# ── Streamlit Cloud ─────────────────────────────────────────────────────────
# Set to "1" when deploying to Streamlit Community Cloud.
# STREAMLIT_SHARING_MODE=1
